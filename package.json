{
  "name": "topical",
  "module": "server/index.ts",
  "type": "module",
  "scripts": {
    "start": "bun server/index.ts",
    "dev": "bun --watch server/index.ts",
    "db:generate": "drizzle-kit generate:pg",
    "db:migrate": "bun server/db/migrate.ts",
    "build:api": "esbuild api/index.src.ts --bundle --platform=node --target=node18 --outfile=api/index.js --format=cjs --packages=external",
    "vercel-build": "cd frontend && npm run build"
  },
  "devDependencies": {
    "@flydotio/dockerfile": "latest",
    "@types/bun": "latest",
    "@types/pg": "^8.11.0",
    "@vercel/node": "^3.0.0",
    "drizzle-kit": "^0.20.14",
    "esbuild": "^0.27.1",
    "typescript": "^5.2.2"
  },
  "peerDependencies": {
    "typescript": "^5.0.0"
  },
  "dependencies": {
    "@google/generative-ai": "^0.24.1",
    "@hono/zod-validator": "^0.1.11",
    "@kinde-oss/kinde-typescript-sdk": "^2.6.2",
    "@radix-ui/react-switch": "^1.2.4",
    "baseline-browser-mapping": "^2.10.21",
    "caniuse-lite": "^1.0.30001790",
    "class-variance-authority": "^0.7.1",
    "drizzle-orm": "^0.29.4",
    "drizzle-zod": "^0.5.1",
    "hono": "^3.12.9",
    "pg": "^8.11.3",
    "postgres": "^3.4.3",
    "zod": "^3.22.4"
  }
}
